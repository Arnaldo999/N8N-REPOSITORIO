    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst apiSecret = 'TRx41hms7_kweGh61FMy5SZhgLs';\nconst timestamp = Math.floor(Date.now() / 1000);\nconst folder = 'cotizaciones';\nconst paramsToSign = `folder=${folder}&timestamp=${timestamp}${apiSecret}`;\nconst signature = crypto.createHash('sha1').update(paramsToSign).digest('hex');\n\nconst binaryKeys = Object.keys($input.first().binary);\nconst logoKey = binaryKeys.find(k => k.toLowerCase().includes('logo')) || binaryKeys[0];\n\nconst binary = {};\nbinary['file'] = $input.first().binary[logoKey];\n\nreturn [{\n  json: {\n    ...($input.first().json),\n    api_key: '238313899787824',\n    timestamp: timestamp.toString(),\n    signature: signature,\n    folder: folder\n  },\n  binary: binary\n}];"
      },
