        "jsCode": "const binaryData = $input.first().binary.data;\nreturn [{\n  json: {\n    url: `data:${binaryData.mimeType || 'application/pdf'};base64,${binaryData.data}`,\n    fileName: `cotizacion_${new Date().toISOString().slice(0,10)}.pdf`\n  },\n  binary: $input.first().binary\n}];"
