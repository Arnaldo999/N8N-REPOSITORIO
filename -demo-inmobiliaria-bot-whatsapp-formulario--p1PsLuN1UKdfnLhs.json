      },
      "id": "at-demo",
      "name": "Airtable - Registrar Lead Demo",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        240,
        -96
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "Xqxq6vy5s2uMmMni",
          "name": "Airtable Token General"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const wb = $('Webhook Formulario').first().json.body;\nconst telRaw = (wb.Telefono || '').toString().trim();\nconst tel = telRaw.startsWith('+') ? telRaw : '+' + telRaw.replace(/\\D/g, '');\nconst op = wb.Operacion === 'venta' ? 'comprar' : 'alquilar';\nconst msg = [\n  'Hola ' + (wb.Nombre || '') + '! Te registraste en *Inmobiliaria Demo*.',\n  '',\n  '*Tu b\\u00fasqueda:*',\n  '- Operaci\\u00f3n: ' + op,\n  '- Tipo: ' + (wb.Tipo_Propiedad || '-') + ', zona ' + (wb.Emprendimiento || '-'),\n  '- Presupuesto: ' + (wb.Presupuesto || '-')\n].join('\\n');\nreturn [{ json: { telefono: tel, mensaje: msg } }];"
      },
      "id": "code-demo",
      "name": "Code - Preparar WA Demo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        -96
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.ycloud.com/v2/whatsapp/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-API-Key",
              "value": "f610d0bb4452b378cec5a0eabcb97059"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: '5493764815689', to: $json.telefono, type: 'text', text: { body: $json.mensaje } }) }}",
        "options": {}
      },
      "id": "ycloud-demo",
