          "mappingMode": "defineBelow",
          "value": {
            "Nombre": "={{ $('Webhook Formulario').item.json.body.Nombre }}",
            "Apellido": "={{ $('Webhook Formulario').item.json.body.Apellido }}",
            "Telefono": "={{ $('Webhook Formulario').item.json.body.Telefono }}",
            "Email": "={{ $('Webhook Formulario').item.json.body.Email }}",
            "Estado": "no_contactado",
            "Operacion": "={{ $('Webhook Formulario').item.json.body.Operacion }}",
            "Tipo_Propiedad": "={{ $('Webhook Formulario').item.json.body.Tipo_Propiedad }}",
            "Presupuesto": "={{ $('Webhook Formulario').item.json.body.Presupuesto }}",
            "Zona": "={{ $('Webhook Formulario').item.json.body.Emprendimiento }}",
            "Llego_WhatsApp": false
          },
          "matchingColumns": [],
          "schema": []
